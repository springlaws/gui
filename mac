-- ПУБЛИЧНЫЙ API
-- ═══════════════════════════════════════════════════

-- Создать цветовой пикер
function NebulaUI:CreateColorPicker(options)
    return ColorPicker.new(options)
end

-- Создать тему пикер
function NebulaUI:CreateThemePicker(callback)
    return ThemePicker.new(callback)
end

-- Получить менеджер биндингов
function NebulaUI:GetKeybindManager()
    return self._KeybindManager
end

-- Зарегистрировать биндинг глобально
function NebulaUI:RegisterKeybind(id, options)
    return self._KeybindManager:Register(id, options)
end

-- Показать Keybind Manager
function NebulaUI:ShowKeybindManager()
    self._KeybindManager:Show()
end

-- Применить тему
function NebulaUI:ApplyTheme(accentColor)
    T.Accent      = accentColor
    T.AccentLight = LerpColor(accentColor, Color3.fromRGB(255, 255, 255), 0.3)
    T.AccentDark  = LerpColor(accentColor, Color3.fromRGB(0, 0, 0), 0.3)
    T.AccentGlow  = LerpColor(accentColor, Color3.fromRGB(255, 255, 255), 0.5)
    T.ToggleOn    = accentColor
    T.SliderFill  = accentColor
end

