-- ДЕМО + ТЕСТ
-- ═══════════════════════════════════════════════════

function NebulaUI:Demo()
    -- Keybind Manager
    local KM = self:GetKeybindManager()
    KM:CreateGui()
    
    -- Регистрируем биндинги
    KM:Register("ToggleMenu", {
        Name = "Открыть меню",
        Description = "Показать/скрыть главное окно",
        Key = Enum.KeyCode.RightControl,
        Category = "Interface",
        Callback = function(held)
            print("Menu toggled!")
        end,
    })
    
    KM:Register("ESP", {
        Name = "ESP Toggle",
        Description = "Включить/выключить ESP",
        Key = Enum.KeyCode.F1,
        Category = "Cheats",
        Callback = function()
            print("ESP toggled!")
        end,
    })
    
    KM:Register("Aimbot", {
        Name = "Aimbot Toggle",
        Description = "Включить/выключить аимбот",
        Key = Enum.KeyCode.F2,
        Category = "Cheats",
        Active = false,
        Callback = function()
            print("Aimbot toggled!")
        end,
    })
    
    KM:Register("Screenshot", {
        Name = "Скриншот",
        Description = "Сохранить скриншот",
        Key = Enum.KeyCode.F12,
        Category = "Utility",
        Callback = function()
            print("Screenshot!")
        end,
    })
    
    -- Color Picker standalone
    local cp = self:CreateColorPicker({
        Name = "Accent Color",
        Default = Color3.fromRGB(124, 58, 237),
        ShowAlpha = true,
        Alpha = 1,
        Callback = function(color, alpha)
            print("Color:", color, "Alpha:", alpha)
            self:ApplyTheme(color)
        end,
    })
    
    -- Theme Picker
    local tp = self:CreateThemePicker(function(color, name)
        print("Theme:", name, color)
        self:ApplyTheme(color)
    end)
    
    -- Горячие клавиши демо
    UserInputService.InputBegan:Connect(function(input, gpe)
        if gpe then return end
        
        if input.KeyCode == Enum.KeyCode.F9 then
            KM:Toggle()
        elseif input.KeyCode == Enum.KeyCode.F10 then
            cp:Show()
        elseif input.KeyCode == Enum.KeyCode.F11 then
            tp:Toggle()
        end
    end)
    
    print("==============================================")
    print("  NEBULA UI v2.1 — DEMO")
    print("  F9  → Keybind Manager")
    print("  F10 → Color Picker")
    print("  F11 → Theme Picker")
    print("==============================================")
    
    return {
        KeybindManager = KM,
        ColorPicker    = cp,
        ThemePicker    = tp,
    }
end

return NebulaUI
