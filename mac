local KeybindManager = {}
KeybindManager.__index = KeybindManager

function KeybindManager.new()
    local self = setmetatable({}, KeybindManager)
    self._binds = {}        -- { id = { key, callback, held, active } }
    self._gui = nil
    self._visible = false
    self._connections = {}
    
    -- Слушаем ввод
    local conn1 = UserInputService.InputBegan:Connect(function(input, gpe)
        if gpe then return end
        
        for id, bind in pairs(self._binds) do
            if bind.key then
                local match = (input.KeyCode == bind.key) 
                    or (input.UserInputType == bind.key)
                    
                if match and bind.active then
                    if bind.callback then
                        task.spawn(bind.callback, true, bind.key)
                    end
                    bind.heldState = true
                end
            end
        end
    end)
    
    local conn2 = UserInputService.InputEnded:Connect(function(input)
        for id, bind in pairs(self._binds) do
            if bind.key then
                local match = (input.KeyCode == bind.key)
                    or (input.UserInputType == bind.key)
                    
                if match and bind.active and bind.heldState then
                    if bind.onReleased then
                        task.spawn(bind.onReleased, bind.key)
                    end
                    bind.heldState = false
                end
            end
        end
    end)
    
    table.insert(self._connections, conn1)
    table.insert(self._connections, conn2)
    
    return self
end

-- Регистрация биндинга
function KeybindManager:Register(id, options)
    self._binds[id] = {
        key         = options.Key,
        callback    = options.Callback,
        onReleased  = options.OnReleased,
        name        = options.Name or id,
        description = options.Description or "",
        active      = options.Active ~= false,
        heldState   = false,
        category    = options.Category or "General",
    }
    
    if self._listFrame then
        self:_RefreshList()
    end
    
    return {
        SetKey = function(key)
            self._binds[id].key = key
        end,
        SetActive = function(state)
            self._binds[id].active = state
        end,
        GetKey = function()
            return self._binds[id].key
        end,
        Unregister = function()
            self._binds[id] = nil
            if self._listFrame then self:_RefreshList() end
        end,
    }
end

-- Обновление биндинга
function KeybindManager:SetBind(id, key)
    if self._binds[id] then
        self._binds[id].key = key
        if self._listFrame then self:_RefreshList() end
    end
end

