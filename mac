        CornerRadius = UDim.new(0, 10),
        Parent = cancelBtn,
    })
    
    confirmBtn.MouseEnter:Connect(function()
        Tween(confirmBtn, { BackgroundColor3 = T.AccentLight }, A.Fast)
    end)
    confirmBtn.MouseLeave:Connect(function()
        Tween(confirmBtn, { BackgroundColor3 = T.Accent }, A.Fast)
    end)
    cancelBtn.MouseEnter:Connect(function()
        Tween(cancelBtn, { BackgroundColor3 = T.SurfaceHover }, A.Fast)
    end)
    cancelBtn.MouseLeave:Connect(function()
        Tween(cancelBtn, { BackgroundColor3 = T.Surface }, A.Fast)
    end)
    
    confirmBtn.MouseButton1Click:Connect(function()
        local finalColor = HSVtoRGB(self._hue, self._sat, self._val)
        self.Color = finalColor
        self._oldPreview.BackgroundColor3 = finalColor
        
        if self.Callback then
            task.spawn(self.Callback, finalColor, self.Alpha)
        end
        
        self:Hide()
    end)
    
    cancelBtn.MouseButton1Click:Connect(function()
        self:Hide()
    end)
    
    -- ─── SV DRAG ──────────────────────────────────
    local svDragging = false
    
    svSquare.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            svDragging = true
            self:_UpdateSVFromInput(input)
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            svDragging = false
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if svDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            self:_UpdateSVFromInput(input)
        end
    end)
    
    -- ─── HUE DRAG ─────────────────────────────────
    local hueDragging = false
    
    hueTrack.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            hueDragging = true
            self:_UpdateHueFromInput(input)
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            hueDragging = false
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if hueDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            self:_UpdateHueFromInput(input)
        end
    end)
    
    self:_UpdateVisuals()
end

-- Обновление SV по вводу
function ColorPicker:_UpdateSVFromInput(input)
    if not self._svSquare then return end
    
    local pct = Vector2.new(
        math.clamp((input.Position.X - self._svSquare.AbsolutePosition.X) / self._svSquare.AbsoluteSize.X, 0, 1),
        math.clamp((input.Position.Y - self._svSquare.AbsolutePosition.Y) / self._svSquare.AbsoluteSize.Y, 0, 1)
    )
    
    self._sat = pct.X
    self._val = 1 - pct.Y
    
    self._svCursor.Position = UDim2.new(pct.X, 0, pct.Y, 0)
    
    local newColor = HSVtoRGB(self._hue, self._sat, self._val)
    self._svCursorIn.BackgroundColor3 = newColor
    
    self:_UpdateInputs(newColor)
    self:_UpdatePreview()
end

-- Обновление Hue по вводу
function ColorPicker:_UpdateHueFromInput(input)
    if not self._hueTrack then return end
    
    local pct = math.clamp(
        (input.Position.X - self._hueTrack.AbsolutePosition.X) / self._hueTrack.AbsoluteSize.X,
        0, 1
    )
    
    self._hue = pct
    
    -- Обновляем thumb
    self._hueThumb.Position = UDim2.new(pct, 0, 0.5, 0)
    
    local hueColor = HSVtoRGB(pct, 1, 1)
    self._hueThumbColor.BackgroundColor3 = hueColor
    
    -- Обновляем SV square background
    self._svSquare.BackgroundColor3 = hueColor
    
    -- Обновляем alpha layer если есть
    if self._alphaLayer then
        self._alphaLayer.BackgroundColor3 = HSVtoRGB(self._hue, self._sat, self._val)
    end
    
    local newColor = HSVtoRGB(self._hue, self._sat, self._val)
    self._svCursorIn.BackgroundColor3 = newColor
    
    self:_UpdateInputs(newColor)
    self:_UpdatePreview()
end

-- Обновление Alpha по вводу
function ColorPicker:_UpdateAlphaFromInput(input)
    if not self._alphaTrack then return end
    
    local pct = math.clamp(
        (input.Position.X - self._alphaTrack.AbsolutePosition.X) / self._alphaTrack.AbsoluteSize.X,
        0, 1
    )
    
    self.Alpha = pct
    self._alphaThumb.Position = UDim2.new(pct, 0, 0.5, 0)
    
    self:_UpdatePreview()
end

-- Обновление инпутов
function ColorPicker:_UpdateInputs(color)
    if not color then
        color = HSVtoRGB(self._hue, self._sat, self._val)
    end
    
    local r = math.floor(color.R * 255 + 0.5)
    local g = math.floor(color.G * 255 + 0.5)
    local b = math.floor(color.B * 255 + 0.5)
    
    if self._rBox then self._rBox.Text = r end
    if self._gBox then self._gBox.Text = g end
    if self._bBox then self._bBox.Text = b end
    if self._hexBox then self._hexBox.Text = string.format("%02X%02X%02X", r, g, b) end
end

-- Обновление preview
function ColorPicker:_UpdatePreview()
    local color = HSVtoRGB(self._hue, self._sat, self._val)
    
    if self._newPreview then
        self._newPreview.BackgroundColor3 = color
        if self.hasAlpha then
            self._newPreview.BackgroundTransparency = 1 - self.Alpha
        end
    end
end

-- Обновление всех визуалов
function ColorPicker:_UpdateVisuals()
    if not self._svSquare then return end
    
    local hueColor = HSVtoRGB(self._hue, 1, 1)
    
    -- SV background
    self._svSquare.BackgroundColor3 = hueColor
    
    -- SV cursor
    self._svCursor.Position = UDim2.new(self._sat, 0, 1 - self._val, 0)
    self._svCursorIn.BackgroundColor3 = HSVtoRGB(self._hue, self._sat, self._val)
    
    -- Hue thumb
    self._hueThumb.Position = UDim2.new(self._hue, 0, 0.5, 0)
    self._hueThumbColor.BackgroundColor3 = hueColor
    
    -- Alpha
    if self._alphaLayer then
        self._alphaLayer.BackgroundColor3 = HSVtoRGB(self._hue, self._sat, self._val)
        self._alphaThumb.Position = UDim2.new(self.Alpha, 0, 0.5, 0)
    end
    
    local color = HSVtoRGB(self._hue, self._sat, self._val)
    self:_UpdateInputs(color)
    self:_UpdatePreview()
end

-- Показать
function ColorPicker:Show()
    if not self._gui then self:_BuildGui() end
    
    self._oldPreview.BackgroundColor3 = self.Color
    self._hue, self._sat, self._val = self.Color:ToHSV()
    self:_UpdateVisuals()
    
    self._overlay.Visible = true
    self._pickerFrame.Visible = true
    self._pickerFrame.BackgroundTransparency = 1
    self._pickerFrame.Position = UDim2.new(0.5, 0, 0.48, 0)
    
    Tween(self._pickerFrame, {
        BackgroundTransparency = 0,
        Position = UDim2.fromScale(0.5, 0.5),
    }, A.Fast)
    
    self._visible = true
end

-- Скрыть
function ColorPicker:Hide()
    if not self._pickerFrame then return end
    
    Tween(self._pickerFrame, {
        BackgroundTransparency = 1,
        Position = UDim2.new(0.5, 0, 0.52, 0),
    }, A.Fast)
    
    task.delay(A.Fast + 0.05, function()
        if self._pickerFrame then
            self._pickerFrame.Visible = false
            self._overlay.Visible = false
        end
    end)
    
    self._visible = false
end

function ColorPicker:SetColor(color)
    self.Color = color
    self._hue, self._sat, self._val = color:ToHSV()
    if self._pickerFrame and self._pickerFrame.Visible then
        self:_UpdateVisuals()
    end
end

function ColorPicker:Destroy()
    if self._gui then self._gui:Destroy() end
end

