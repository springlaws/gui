    if not self._gui then self:CreateGui() end
    
    self._overlay.Visible = true
    self._mainFrame.Visible = true
    self._mainFrame.Size = UDim2.fromOffset(520, 520)
    self._mainFrame.BackgroundTransparency = 1
    
    Tween(self._mainFrame, { BackgroundTransparency = 0 }, A.Fast)
    
    self._visible = true
end

function KeybindManager:Hide()
    if not self._mainFrame then return end
    
    Tween(self._mainFrame, { BackgroundTransparency = 1 }, A.Fast)
    task.delay(A.Fast, function()
        if self._mainFrame then
            self._mainFrame.Visible = false
            self._overlay.Visible = false
        end
    end)
    
    self._visible = false
end

function KeybindManager:Toggle()
    if self._visible then self:Hide() else self:Show() end
end

function KeybindManager:Destroy()
    for _, conn in ipairs(self._connections) do
        conn:Disconnect()
    end
    if self._gui then self._gui:Destroy() end
end

-- Глобальный менеджер
NebulaUI._KeybindManager = KeybindManager.new()

