function ThemePicker:Show()
    if not self._gui then self:_Build() end
    
    self._overlay.Visible = true
    self._frame.Visible = true
    self._frame.BackgroundTransparency = 1
    
    Tween(self._frame, { BackgroundTransparency = 0 }, A.Fast)
    self._visible = true
end

function ThemePicker:Hide()
    if not self._frame then return end
    
    Tween(self._frame, { BackgroundTransparency = 1 }, A.Fast)
    task.delay(A.Fast + 0.05, function()
        if self._frame then
            self._frame.Visible = false
            self._overlay.Visible = false
        end
    end)
    
    self._visible = false
end

function ThemePicker:Toggle()
    if self._visible then self:Hide() else self:Show() end
end

