-- Обновление списка
function KeybindManager:_RefreshList()
    if not self._listFrame then return end
    
    -- Удаляем старые
    for _, child in ipairs(self._listFrame:GetChildren()) do
        if not child:IsA("UIComponent") and not child:IsA("UIPadding") and not child:IsA("UIListLayout") then
            child:Destroy()
        end
    end
    
    local searchTerm = (self._searchBox and self._searchBox.Text:lower()) or ""
    
    -- Группируем по категориям
    local categories = {}
    for id, bind in pairs(self._binds) do
        if searchTerm == "" or bind.name:lower():find(searchTerm, 1, true) then
            local cat = bind.category or "General"
            if not categories[cat] then
                categories[cat] = {}
            end
            table.insert(categories[cat], { id = id, data = bind })
        end
    end
    
    local layoutOrder = 0
    
    for catName, binds in pairs(categories) do
        layoutOrder += 1
        
        -- Категория
        local catLabel = Create("TextLabel", {
            Font = F.SemiBold,
            Text = catName:upper(),
            TextColor3 = T.AccentLight,
            TextSize = 10,
            TextXAlignment = Enum.TextXAlignment.Left,
            AutomaticSize = Enum.AutomaticSize.Y,
            BackgroundTransparency = 1,
            LayoutOrder = layoutOrder,
            Size = UDim2.new(1, 0, 0, 18),
            ZIndex = 103,
            Parent = self._listFrame,
        })
        
        Create("UIPadding", {
            PaddingLeft = UDim.new(0, 6),
            Parent = catLabel,
        })
        
        for _, bindInfo in ipairs(binds) do
            layoutOrder += 1
            self:_CreateBindItem(bindInfo.id, bindInfo.data, layoutOrder)
        end
    end
    
    -- Пусто
    if next(categories) == nil then
        Create("TextLabel", {
            Font = F.Medium,
            Text = "Биндинги не найдены",
            TextColor3 = T.TextMuted,
            TextSize = 13,
            AnchorPoint = Vector2.new(0.5, 0),
            AutomaticSize = Enum.AutomaticSize.Y,
            BackgroundTransparency = 1,
            Position = UDim2.new(0.5, 0, 0, 20),
            Size = UDim2.new(0, 0, 0, 0),
            ZIndex = 103,
            Parent = self._listFrame,
        })
    end
end

