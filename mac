-- Создание Instance с пропсами
local function Create(className, props)
    local inst = Instance.new(className)
    local parent = props and props.Parent
    
    if props then
        for k, v in pairs(props) do
            if k ~= "Parent" and k ~= "Children" then
                pcall(function() inst[k] = v end)
            end
        end
        if props.Children then
            for _, child in ipairs(props.Children) do
                child.Parent = inst
            end
        end
    end
    
    if parent then inst.Parent = parent end
    return inst
end

-- Твин-анимация
local function Tween(instance, properties, duration, style, direction)
    local info = TweenInfo.new(
        duration or A.Duration,
        style or A.EasingStyle,
        direction or A.EasingOut
    )
    local t = TweenService:Create(instance, info, properties)
    t:Play()
    return t
end

-- Lerp цвета
local function LerpColor(a, b, t)
    return Color3.new(
        a.R + (b.R - a.R) * t,
        a.G + (b.G - a.G) * t,
        a.B + (b.B - a.B) * t
    )
end

-- RGB → HSV
local function RGBtoHSV(color)
    return color:ToHSV()
end

-- HSV → RGB
local function HSVtoRGB(h, s, v)
    return Color3.fromHSV(h, s, v)
end

-- Hex → Color3
local function HexToColor(hex)
    hex = hex:gsub("#", ""):upper()
    if #hex ~= 6 then return Color3.new(1, 1, 1) end
    local r = tonumber(hex:sub(1, 2), 16) or 0
    local g = tonumber(hex:sub(3, 4), 16) or 0
    local b = tonumber(hex:sub(5, 6), 16) or 0
    return Color3.fromRGB(r, g, b)
end

-- Color3 → Hex
local function ColorToHex(color)
    return string.format("#%02X%02X%02X",
        math.floor(color.R * 255 + 0.5),
        math.floor(color.G * 255 + 0.5),
        math.floor(color.B * 255 + 0.5)
    )
end

-- Яркость цвета (для определения цвета текста)
local function GetLuminance(color)
    return 0.299 * color.R + 0.587 * color.G + 0.114 * color.B
end

