		local function Toggle(State)
			if State then
				Tween(checkmark, TweenInfo.new(tweensettings.duration, tweensettings.easingStyle), {
					Size = UDim2.new(checkmark.Size.X.Scale, 12, checkmark.Size.Y.Scale, checkmark.Size.Y.Offset)
				}):Play()
				Tween(settingName, TweenInfo.new(tweensettings.duration, tweensettings.easingStyle), {
					TextTransparency = 0.2
				}):Play()
				checkmark.TextTransparency = 0
			else
				Tween(checkmark, TweenInfo.new(tweensettings.duration, tweensettings.easingStyle), {
					Size = UDim2.new(checkmark.Size.X.Scale, -13, checkmark.Size.Y.Scale, checkmark.Size.Y.Offset)
				}):Play()
				Tween(settingName, TweenInfo.new(tweensettings.duration, tweensettings.easingStyle), {
					TextTransparency = 0.5
				}):Play()
				checkmark.TextTransparency = 1
			end
		end

		local toggled = Settings.Default
		Toggle(toggled)

		globalSetting.MouseButton1Click:Connect(function()
			toggled = not toggled
			Toggle(toggled)
			task.spawn(function()
				if Settings.Callback then
					Settings.Callback(toggled)
				end
			end)
		end)

		return GlobalSettingFunctions
	end

