					local focused = false
					local binded = Settings.Default or nil

					if binded then
						binderBox.Text = tostring(binded):match("KeyCode%.(.+)") or binded.Name or tostring(binded)
					end

					binderBox.Focused:Connect(function()
						focused = true
						binderBox.Text = ""
					end)

					binderBox.FocusLost:Connect(function()
						focused = false
					end)

					UserInputService.InputBegan:Connect(function(input)
						if focused then
							if input.UserInputType == Enum.UserInputType.Keyboard then
								binded = input.KeyCode
								binderBox.Text = input.KeyCode.Name
								binderBox:ReleaseFocus()
							end
						elseif (input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == binded) or (input.UserInputType == binded) then
							if KeybindFunctions.Settings.Callback then
								KeybindFunctions.Settings.Callback(binded)
							end
						end
					end)

					function KeybindFunctions:GetBind()
						return binded
					end

					if Flag then
						MacLib.Options[Flag] = KeybindFunctions
					end
					return KeybindFunctions
				end

