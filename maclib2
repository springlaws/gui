						Percent = function(value)
							local percentage = (value - (Settings.Minimum or 0)) / ((Settings.Maximum or 100) - (Settings.Minimum or 0)) * 100
							return tostring(math.round(percentage)) .. "%"
						end,
						Round = function(value)
							return tostring(math.round(value))
						end,
						Value = function(value)
							return tostring(math.floor(value * 10) / 10)
						end
					}

					local ValueDisplayMethod = DisplayMethods[Settings.DisplayMethod] or DisplayMethods.Value

					local function SetValue(val)
						local minimum = Settings.Minimum or 0
						local maximum = Settings.Maximum or 100
						local posXScale = (val - minimum) / (maximum - minimum)
						posXScale = math.clamp(posXScale, 0, 1)

						sliderHead.Position = UDim2.new(posXScale, 0, 0.5, 0)
						finalValue = posXScale * (maximum - minimum) + minimum
						sliderValue.Text = (Settings.Prefix or "") .. ValueDisplayMethod(finalValue) .. (Settings.Suffix or "")

						pcall(function()
							if Settings.Callback then
								Settings.Callback(finalValue)
							end
						end)

						SliderFunctions.Value = finalValue
					end

					SetValue(finalValue)

					sliderHead.MouseButton1Down:Connect(function()
						dragging = true
					end)

					UserInputService.InputEnded:Connect(function(input)
						if input.UserInputType == Enum.UserInputType.MouseButton1 then
							dragging = false
						end
					end)

					UserInputService.InputChanged:Connect(function(input)
						if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
							local mousePos = UserInputService:GetMouseLocation().X
							local barPos = sliderBar.AbsolutePosition.X
							local barSize = sliderBar.AbsoluteSize.X
							local relativePos = math.clamp((mousePos - barPos) / barSize, 0, 1)
							local minimum = Settings.Minimum or 0
							local maximum = Settings.Maximum or 100
							local newValue = relativePos * (maximum - minimum) + minimum
							SetValue(newValue)
						end
					end)

					function SliderFunctions:UpdateValue(Value)
						SetValue(tonumber(Value) or 0)
					end

					function SliderFunctions:GetValue()
						return finalValue
					end

					if Flag then
						MacLib.Options[Flag] = SliderFunctions
					end
					return SliderFunctions
				end

